  "analysis_methods": [
    {
      "id": "trend",
      "name": "趋势分析",
      "description": "Analyze daily, weekly or monthly movement and compare with baseline.",
      "inputs": [
        "metric",
        "time_field",
        "time_grain",
        "comparison_baseline"
      ],
      "outputs": [
        "trend_table",
        "trend_chart",
        "inflection_points"
      ],
      "recommended_skills": [
        "data-analysis",
        "data-visualization"
      ]
    },
    {
      "id": "funnel",
      "name": "漏斗分析",
      "description": "Analyze stage volume and conversion across register, lead, opportunity, visit, test drive, order and handover.",
      "inputs": [
        "stage_definitions",
        "distinct_keys",
        "valid_filters",
        "dimensions"
      ],
      "outputs": [
        "stage_counts",
        "conversion_rates",
        "stage_dropoff"
      ],
      "recommended_skills": [
        "exploratory-data-analysis",
        "sql-query-generation",
        "data-visualization"
      ]
    },
    {
      "id": "contribution",
      "name": "贡献度分析",
      "description": "Break growth or decline into dimension-level contribution.",
      "inputs": [
        "metric",
        "dimension",
        "current_period",
        "baseline_period"
      ],
      "outputs": [
        "contribution_rank",
        "positive_negative_drivers",
        "waterfall_data"
      ],
      "recommended_skills": [
        "data-analysis",
        "sql-query-generation",
        "analytics-reporting"
      ]
    },
    {
      "id": "structure",
      "name": "结构分析",
      "description": "Compare mix shift by region, channel, dealer, series, campaign or customer segment.",
      "inputs": [
        "metric",
        "dimension",
        "period"
      ],
      "outputs": [
        "mix_table",
        "share_change",
        "segment_summary"
      ],
      "recommended_skills": [
        "data-analysis",
        "data-visualization"
      ]
    },
    {
      "id": "stage_latency",
      "name": "时效分析",
      "description": "Measure delay between sales funnel stages and follow-up SLA.",
      "inputs": [
        "start_time",
        "end_time",
        "latency_metric",
        "dimension"
      ],
      "outputs": [
        "latency_distribution",
        "sla_breach_list",
        "latency_driver"
      ],
      "recommended_skills": [
        "sql-query-generation",
        "exploratory-data-analysis"
      ]
    },
    {
      "id": "cohort",
      "name": "Cohort 分析",
      "description": "Track downstream conversion for cohorts entering at different times or channels.",
      "inputs": [
        "cohort_field",
        "entry_time",
        "conversion_events",
        "maturity_window"
      ],
      "outputs": [
        "cohort_matrix",
        "matured_conversion",
        "cohort_comparison"
      ],
      "recommended_skills": [
        "exploratory-data-analysis",
        "data-visualization"
      ]
    },
    {
      "id": "anomaly_detection",
      "name": "异常检测",
      "description": "Detect sudden change, outlier or missing activity.",
      "inputs": [
        "metric",
        "time_field",
        "dimension",
        "threshold"
      ],
      "outputs": [
        "anomaly_list",
        "severity",
        "possible_causes"
      ],
      "recommended_skills": [
        "data-cleaning",
        "exploratory-data-analysis"
      ]
    },
    {
      "id": "reason_analysis",
      "name": "原因枚举分析",
      "description": "Analyze battle fail, refusal and cancellation reasons.",
      "inputs": [
        "reason_field",
        "metric",
        "dimension"
      ],
      "outputs": [
        "reason_rank",
        "reason_share",
        "reason_change"
      ],
      "recommended_skills": [
        "churn-analysis",
        "competitive-battlecard-creation",
        "analytics-reporting"
      ]
    },
    {
      "id": "target_gap",
      "name": "目标差距分析",
      "description": "Compare actual performance with target and calculate gap.",
      "inputs": [
        "actual_metric",
        "target_metric",
        "period",
        "dimension"
      ],
      "outputs": [
        "gap_table",
        "gap_contribution",
        "risk_list"
      ],
      "recommended_skills": [
        "financial-modeling",
        "analytics-reporting"
      ]
    },
    {
      "id": "potential_scoring",
      "name": "潜力评分",
      "description": "Score objects by historical performance, conversion, capacity proxy and growth headroom.",
      "inputs": [
        "object",
        "candidate_metrics",
        "benchmark_group",
        "weights"
      ],
      "outputs": [
        "score_table",
        "priority_list",
        "recommended_actions"
      ],
      "recommended_skills": [
        "financial-modeling",
        "proposal-generation",
        "analytics-reporting"
      ]
    }
  ],
  "metrics": [
    {
      "id": "lead_count",
      "name": "线索量",
      "definition": "Distinct leads in selected period.",
      "formula": "count_distinct(leads_id)",
      "required_fields": [
        "leads_id",
        "leads_create_time"
      ],
      "default_filters": [
        "leads_id is not null"
      ],
      "ba_confirmation_required": true
    },
    {
      "id": "opportunity_count",
      "name": "机会量",
      "definition": "Distinct sales opportunities in selected period.",
      "formula": "count_distinct(oppty_id)",
      "required_fields": [
        "oppty_id",
        "oppty_create_time"
      ],
      "default_filters": [
        "oppty_id is not null",
        "oppty_deleted_desc != 'deleted' when confirmed"
      ],
      "ba_confirmation_required": true
    },
    {
      "id": "valid_visit_count",
      "name": "有效到店量",
      "definition": "Distinct valid showroom visits.",
      "formula": "count_distinct(visit_id)",
      "required_fields": [
        "visit_id",
        "visit_arrival_time",
        "visit_valid_flag"
      ],
      "default_filters": [
        "visit_id is not null",
        "visit_valid_flag indicates valid"
      ],
      "ba_confirmation_required": true
    },
    {
      "id": "test_drive_count",
      "name": "试驾量",
      "definition": "Distinct non-deleted test drives.",
      "formula": "count_distinct(td_id)",
      "required_fields": [
        "td_id",
        "td_start_time",
        "td_deleted_desc"
      ],
      "default_filters": [
        "td_id is not null"
      ],
      "ba_confirmation_required": true
    },
    {
      "id": "order_count",
      "name": "订单量",
      "definition": "Distinct vehicle orders.",
      "formula": "count_distinct(order_id)",
      "required_fields": [
        "order_id",
        "order_create_time",
        "order_deleted_desc",
        "order_cancel_flag"
      ],
      "default_filters": [
        "order_id is not null"
      ],
      "ba_confirmation_required": true
    },
    {
      "id": "handover_count",
      "name": "交车量",
      "definition": "Orders with handover time or handover intake flag.",
      "formula": "count_distinct(order_id where order_handover_time is not null or order_handover_intake_flag indicates yes)",
      "required_fields": [
        "order_id",
        "order_handover_time",
        "order_handover_intake_flag"
      ],
      "default_filters": [
        "order_id is not null"
      ],
      "ba_confirmation_required": true
    },
    {
      "id": "first_follow_latency",
      "name": "首次跟进时效",
      "definition": "Minutes from lead or opportunity creation to first follow-up.",
      "formula": "avg(leads_first_follow_mindiff) or avg(oppty_first_oppty_follow_mindiff)",
      "required_fields": [
        "leads_first_follow_mindiff",
        "oppty_first_oppty_follow_mindiff"
      ],
      "default_filters": [
        "latency >= 0"
      ],
      "ba_confirmation_required": true
    },
    {
      "id": "order_cancel_rate",
      "name": "订单取消率",
      "definition": "Cancelled orders divided by total orders.",
      "formula": "count_distinct(order_id where order_cancel_flag indicates yes) / count_distinct(order_id)",
      "required_fields": [
        "order_id",
        "order_cancel_flag"
      ],
      "default_filters": [
        "order_id is not null"
      ],
      "ba_confirmation_required": true
    }
  ],
